{
  "name": "airlock",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @airlock/app",
    "build": "npm run build -w @airlock/app",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p packages/agent-core --noEmit && tsc -p packages/app --noEmit",
    "lint": "biome check .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "package": "npm run package -w @airlock/app"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
