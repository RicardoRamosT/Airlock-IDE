{
  "name": "@airlock/app",
  "version": "0.3.0",
  "description": "Terminal-first AI IDE where the agent can't read your secrets",
  "author": "Ricardo Ramos Treviño",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.ricardoramos.airlock",
    "productName": "AirLock",
    "electronVersion": "42.3.2",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "extraResources": [
      {
        "from": "resources/mcp-docs",
        "to": "mcp-docs"
      },
      {
        "from": "../../node_modules/typescript",
        "to": "ts-lib"
      },
      {
        "from": "../../node_modules/typescript-language-server",
        "to": "lsp-server"
      },
      {
        "from": "resources/statusline-emit.sh",
        "to": "statusline-emit.sh"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "identity": "-",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "AirLock-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.18.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3"
  }
}
